{
  "name": "parabank-playwright",
  "version": "1.0.0",
  "description": "E2E test automation for ParaBank using playwright-bdd",
  "scripts": {
    "test": "npx bddgen && npx playwright test",
    "test:headed": "npx bddgen && npx playwright test --headed",
    "test:ui-mode": "npx bddgen && npx playwright test --ui",
    "test:debug": "npx bddgen && npx playwright test --debug",
    "report": "npx playwright show-report",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.6.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "playwright-bdd": "^8.5.0",
    "typescript": "^5.8.0",
    "uuid": "^11.1.0"
  }
}
